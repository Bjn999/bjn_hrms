# Next.js Frontend Environment Variables

# The base URL of the backend server (without trailing slash)
NEXT_PUBLIC_BASE_URL=http://localhost:8000

# The admin API endpoint URL
NEXT_PUBLIC_API_URL=http://localhost:8000/api/admin

# The folder where employee photos and CVs/files are uploaded
NEXT_PUBLIC_UPLOAD_URL=http://localhost:8000/assets/admin/uploads
